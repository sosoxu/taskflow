server:
  http_port: 8080
  grpc_port: 50051
  # tls:
  #   enabled: true
  #   cert_path: /path/to/cert.pem
  #   key_path: /path/to/key.pem
  #   ca_path: /path/to/ca.pem

database:
  host: localhost
  port: 5432
  name: taskflow
  user: taskflow
  password: ""           # 必填
  min_connections: 5
  max_connections: 20

auth:
  jwt_secret: ""         # 必填，>=32 字符
  access_token_ttl: 86400   # 秒
  refresh_token_ttl: 604800 # 秒

encryption:
  aes_key: ""            # 必填，32 字符

log:
  level: info
  file_path: logs/scheduler.log

schedule:
  dag_drive_interval: 2       # DAG 驱动间隔（秒）
  heartbeat_check_interval: 10
  heartbeat_timeout: 30
  timeout_check_interval: 10
  leader_lease_interval: 5
